{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Account Switcher",
  "version": "0.1.0",
  "identifier": "dev.hoangphan.ai-account-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Account Switcher",
        "width": 1080,
        "height": 740,
        "minWidth": 820,
        "minHeight": 560,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": []
  }
}
